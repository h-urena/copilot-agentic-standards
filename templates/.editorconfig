# EditorConfig — consistent formatting across editors and IDEs.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{py,pyi}]
indent_size = 4

[*.{cs,csx}]
indent_size = 4

[*.{json,jsonc}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab

[Dockerfile*]
indent_size = 2

[*.{sln,csproj,props,targets}]
indent_size = 2
charset = utf-8-bom
